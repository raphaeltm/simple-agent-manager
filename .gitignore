.cache/

# Codex local state. CODEX_HOME points at the repo's .codex/ (see
# .devcontainer/devcontainer.json) so the project-scoped config survives container
# rebuilds. Codex ALSO writes mutable runtime state here — sqlite DBs
# (goals/logs/memories/state) plus their -wal/-shm sidecars, auth, history, model
# caches, downloaded plugins, and session/shell snapshots — which must NEVER be
# committed. Ignore ALL of .codex/ and track ONLY the config we author by hand.
.codex/*
!.codex/config.toml
# Playwright audit screenshots write under apps/web cwd, not the repo root
**/.codex/tmp/

# Ephemeral agent scratch space — screenshots, debug dumps, downloads, notes.
# Anything that should NOT be committed goes in .tmp/ (see .tmp/README.md).
.tmp/
!.tmp/README.md

# Playwright MCP session artifacts (page snapshots, login scripts)
.playwright-mcp/

# SAM library downloads (download_library_file MCP tool target — canonical copies live in the platform library)
.library/

# /do workflow state (ephemeral, per-session)
.do-state.md

# /workflow orchestrator state (ephemeral, per-session)
.workflow-state.md
