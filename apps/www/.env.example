# Website Configuration
SITE_URL=https://www.simple-agent-manager.org
PUBLIC_BASE_DOMAIN=simple-agent-manager.org

# Brand Customization (optional)
# Uncomment and customize these to override the default SAM branding
# This allows forks to maintain their own branding without merge conflicts

# BRAND_NAME=YourOrg
# BRAND_TITLE=YourOrg SAM Docs
# BRAND_DESCRIPTION=Documentation for YourOrg Simple Agent Manager — ephemeral AI coding environments on Cloudflare Workers + multi-cloud VMs.
# BRAND_GITHUB_ORG=yourorg
# BRAND_GITHUB_REPO=simple-agent-manager
# BRAND_LOGO_PATH=./src/assets/logo-yourorg.png
# BRAND_CUSTOM_CSS=./src/styles/brand-yourorg.css

# Example: Defang branding
# BRAND_NAME=Defang
# BRAND_TITLE=Defang SAM Docs
# BRAND_GITHUB_ORG=defanglabs
# BRAND_LOGO_PATH=./src/assets/logo-defang.png
# BRAND_CUSTOM_CSS=./src/styles/brand-defang.css
