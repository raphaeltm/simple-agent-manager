---
import NodeGrid from './NodeGrid.astro';

const baseDomain = import.meta.env.PUBLIC_BASE_DOMAIN || 'simple-agent-manager.org';
const appUrl = `https://app.${baseDomain}`;
---

<section class="hero">
  <NodeGrid />
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="container hero-content">
    <div class="hero-badge animate-on-scroll">
      <span class="badge-dot"></span>
      Open Source & Self-Hosted
    </div>

    <h1 class="hero-title animate-on-scroll">
      The open-source platform for<br /><span class="gradient-text">multi-agent orchestration</span>
    </h1>

    <p class="hero-subtitle animate-on-scroll">
      Every agent runs in its own isolated container on your cloud.
      Run 5 or 500 in parallel — SAM handles provisioning, scheduling, and cleanup.
    </p>

    <div class="hero-actions animate-on-scroll">
      <a href={appUrl} class="btn-hero btn-hero-primary">
        Get Started
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="https://github.com/raphaeltm/simple-agent-manager" class="btn-hero btn-hero-secondary" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        View on GitHub
      </a>
    </div>

    <!-- Agent workspace mockup -->
    <div class="workspace-preview animate-on-scroll">
      <div class="terminal-chrome">
        <div class="terminal-dots">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </div>
        <span class="terminal-title">workspace — api-service</span>
      </div>
      <div class="workspace-body">
        <div class="agent-message assistant-msg">
          <div class="msg-header">
            <span class="agent-badge">Claude Code</span>
            <span class="msg-time">just now</span>
          </div>
          <p class="msg-text">I'll refactor the auth middleware. The frontend and API tests can run in parallel — let me dispatch two agents.</p>
        </div>

        <div class="tool-call">
          <div class="tool-header">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            <span class="tool-name">Edit</span>
            <span class="tool-path">src/middleware/auth.ts</span>
            <span class="tool-diff">+42 -18</span>
          </div>
        </div>

        <div class="tool-call dispatch-call">
          <div class="tool-header">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span class="tool-name">Dispatch</span>
            <span class="tool-path">2 sub-agents &rarr; frontend-tests, api-tests</span>
          </div>
        </div>

        <div class="sub-agents">
          <div class="sub-agent">
            <span class="sub-agent-dot running"></span>
            <span class="sub-agent-label">frontend-tests</span>
            <span class="sub-agent-status">running</span>
          </div>
          <div class="sub-agent">
            <div class="sub-agent-dot running"></div>
            <span class="sub-agent-label">api-tests</span>
            <span class="sub-agent-status">running</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 160px 0 80px;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 180px 0 120px;
    }
  }

  .hero-glow {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse at center, var(--color-accent-glow) 0%, transparent 70%);
    pointer-events: none;
    animation: glow-pulse 6s ease-in-out infinite;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    padding: 6px 16px;
    background: var(--glass-bg-subtle);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 100px;
    margin-bottom: 32px;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: glow-pulse 2s ease-in-out infinite;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 4rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-fg-primary);
    margin-bottom: 24px;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-success) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-fg-muted);
    max-width: 600px;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-bottom: 64px;
  }

  .btn-hero {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 12px 28px;
    border-radius: var(--radius-md);
    transition: all 0.2s;
    border: none;
    cursor: pointer;
  }

  .btn-hero-primary {
    background: var(--color-accent);
    color: white;
  }

  .btn-hero-primary:hover {
    background: var(--color-accent-hover);
    color: white;
    transform: translateY(-1px);
  }

  .btn-hero-secondary {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    color: var(--color-fg-primary);
    border: 1px solid var(--glass-border);
  }

  .btn-hero-secondary:hover {
    background: var(--glass-bg-subtle);
    color: var(--color-fg-primary);
    border-color: var(--glass-border-hover);
  }

  /* Workspace mockup */
  .workspace-preview {
    width: 100%;
    max-width: 720px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    box-shadow:
      var(--glass-shadow),
      0 0 80px var(--color-accent-glow);
  }

  .terminal-chrome {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: rgba(19, 32, 29, 0.6);
    border-bottom: 1px solid var(--glass-border);
  }

  .terminal-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot-red { background: #ef4444; }
  .dot-yellow { background: #f59e0b; }
  .dot-green { background: #22c55e; }

  .terminal-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-fg-dim);
  }

  .workspace-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* Agent message */
  .agent-message {
    padding: 16px;
    border-radius: var(--radius-md);
    background: var(--glass-bg-subtle);
    border: 1px solid var(--glass-border);
  }

  .msg-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .agent-badge {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-accent);
    background: var(--color-accent-glow);
    padding: 2px 10px;
    border-radius: 100px;
    letter-spacing: 0.02em;
  }

  .msg-time {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-fg-dim);
  }

  .msg-text {
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
  }

  /* Tool calls */
  .tool-call {
    padding: 10px 16px;
    border-radius: var(--radius-md);
    background: var(--glass-bg-subtle);
    border: 1px solid var(--glass-border);
  }

  .dispatch-call {
    border-color: rgba(22, 163, 74, 0.2);
    background: rgba(22, 163, 74, 0.06);
  }

  /* Sub-agents */
  .sub-agents {
    display: flex;
    gap: 8px;
  }

  .sub-agent {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-radius: var(--radius-md);
    background: var(--glass-bg-subtle);
    border: 1px solid var(--glass-border);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .sub-agent-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .sub-agent-dot.running {
    background: var(--color-accent);
    animation: glow-pulse 2s ease-in-out infinite;
  }

  .sub-agent-label {
    color: var(--color-fg-muted);
  }

  .sub-agent-status {
    margin-left: auto;
    color: var(--color-accent);
    font-size: 0.6875rem;
  }

  .tool-header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-fg-dim);
  }

  .tool-header svg {
    color: var(--color-fg-dim);
    flex-shrink: 0;
  }

  .tool-name {
    color: var(--color-accent);
    font-weight: 500;
  }

  .tool-path {
    color: var(--color-fg-muted);
  }

  .tool-diff {
    margin-left: auto;
    color: var(--color-success);
    font-size: 0.6875rem;
  }

  /* Permission prompt */
</style>
