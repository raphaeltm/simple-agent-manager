---
const rows = [
  {
    label: 'Your code runs on',
    sam: 'Your cloud (Hetzner, Scaleway, Vultr, GCP)',
    managed: 'Their infrastructure',
    selfHosted: 'Your infra (AWS, GCP, K8s)',
    samWins: true,
  },
  {
    label: 'Agent choice',
    sam: 'Claude Code, Codex, Gemini CLI, Mistral Vibe, OpenCode, Amp',
    managed: 'Their proprietary agent',
    selfHosted: 'Varies (Claude, OpenAI)',
    samWins: true,
  },
  {
    label: 'Open source',
    sam: 'AGPL-3.0 license',
    managed: 'Proprietary',
    selfHosted: 'Open-source core',
    samWins: true,
  },
  {
    label: 'Control plane',
    sam: 'Workers Paid base plan',
    managed: 'Bundled into pricing',
    selfHosted: 'You host it (K8s / Docker)',
    samWins: true,
  },
  {
    label: 'Infrastructure cost',
    sam: 'Cloud bill direct to provider',
    managed: 'From $20/mo (compute + inference)',
    selfHosted: 'Your cloud bill + license fees',
    samWins: true,
  },
  {
    label: 'Self-hostable',
    sam: 'Fully — control plane + VMs',
    managed: 'No',
    selfHosted: 'Yes — Terraform + K8s required',
    samWins: true,
  },
  {
    label: 'Setup effort',
    sam: 'Deploy to Cloudflare + connect cloud',
    managed: 'Zero config',
    selfHosted: 'Terraform + cluster management',
    samWins: false,
  },
  {
    label: 'Data sovereignty',
    sam: 'Code runs on your cloud; control plane data in Cloudflare',
    managed: 'Vendor-managed',
    selfHosted: 'Full — your infrastructure',
    samWins: true,
  },
];
---

<section id="comparison" class="section">
  <div class="container">
    <div class="comparison-header animate-on-scroll">
      <span class="section-label">Comparison</span>
      <h2 class="section-title">How SAM stacks up</h2>
      <p class="section-subtitle">
        Own your infrastructure. Choose your agent. Pay cloud prices.
      </p>
    </div>

    <div class="table-wrapper animate-on-scroll">
      <table class="comparison-table">
        <thead>
          <tr>
            <th class="col-label"></th>
            <th class="col-sam">
              <div class="col-header-content">
                <img src="/images/sam-head.png" width="20" height="20" alt="" aria-hidden="true" style="border-radius: 4px;" />
                SAM
              </div>
            </th>
            <th class="col-other">
              <div class="col-header-content col-header-managed">
                Managed AI Platforms
                <span class="col-examples">Devin, Ona</span>
              </div>
            </th>
            <th class="col-other">
              <div class="col-header-content col-header-selfhosted">
                Self-Hosted CDEs
                <span class="col-examples">Coder</span>
              </div>
            </th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <td class="col-label">{row.label}</td>
              <td class={`col-sam ${row.samWins ? 'highlight' : ''}`}>{row.sam}</td>
              <td class="col-other">{row.managed}</td>
              <td class="col-other">{row.selfHosted}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="comparison-footnote animate-on-scroll">
      SAM infrastructure costs are compute only — bring your own API keys for AI providers.
      Managed platform pricing bundles compute and model inference.
    </p>
  </div>
</section>

<style>
  .comparison-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .comparison-header .section-subtitle {
    margin-left: auto;
    margin-right: auto;
  }

  .table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--glass-shadow), 0 0 60px rgba(22, 163, 74, 0.04);
    padding: 8px;
  }

  .comparison-table {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }

  .comparison-table th,
  .comparison-table td {
    padding: 14px 20px;
    text-align: left;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .comparison-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-fg-primary);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 16px;
  }

  .col-header-content {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .col-header-managed,
  .col-header-selfhosted {
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }

  .col-examples {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-fg-dim);
  }

  .col-label {
    color: var(--color-fg-muted);
    font-weight: 500;
    white-space: nowrap;
  }

  .col-sam {
    color: var(--color-fg-primary);
  }

  .col-sam.highlight {
    color: var(--color-accent);
    font-weight: 500;
  }

  .col-other {
    color: var(--color-fg-dim);
  }

  .comparison-footnote {
    text-align: center;
    font-size: 0.8125rem;
    color: var(--color-fg-dim);
    margin-top: 24px;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.5;
  }
</style>
