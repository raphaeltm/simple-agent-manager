---
import OptimizedFeatureImage from './OptimizedFeatureImage.astro';
import type { FeatureSection } from '../data/features';

interface Props {
  feature: FeatureSection;
  prevFeature?: { slug: string; label: string } | null;
  nextFeature?: { slug: string; label: string } | null;
}

const baseDomain = import.meta.env.PUBLIC_BASE_DOMAIN || 'simple-agent-manager.org';
const appUrl = `https://app.${baseDomain}`;

const { feature, prevFeature, nextFeature } = Astro.props;
---

<section class="feature-hero">
  <div class="container">
    <a href="/#features" class="back-link animate-on-scroll">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
      All Features
    </a>

    <span class="section-label animate-on-scroll">{feature.label}</span>
    <h1 class="feature-hero-title animate-on-scroll" set:html={feature.title.replace('\n', '<br />')} />
    <p class="feature-hero-subtitle animate-on-scroll">{feature.subtitle}</p>

    <div class="feature-hero-image animate-on-scroll">
      <OptimizedFeatureImage src={feature.screenshots[0].src} alt={feature.screenshots[0].alt} loading="eager" />
    </div>
  </div>
</section>

<section class="feature-details">
  <div class="container">
    {feature.details.map((detail, i) => (
      <div class={`detail-row ${i % 2 === 1 ? 'detail-row-reverse' : ''} animate-on-scroll`} style={`transition-delay: ${i * 100}ms`}>
        <div class="detail-text">
          <h2 class="detail-headline">{detail.headline}</h2>
          <p class="detail-body">{detail.body}</p>
        </div>
        <div class="detail-image">
          <OptimizedFeatureImage src={detail.screenshot.src} alt={detail.screenshot.alt} />
          <span class="detail-caption">{detail.screenshot.caption}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<section class="feature-nav">
  <div class="container">
    <div class="feature-nav-inner">
      {prevFeature ? (
        <a href={`/features/${prevFeature.slug}/`} class="feature-nav-link feature-nav-prev">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          <span>
            <span class="nav-label">Previous</span>
            <span class="nav-title">{prevFeature.label}</span>
          </span>
        </a>
      ) : <div />}
      {nextFeature ? (
        <a href={`/features/${nextFeature.slug}/`} class="feature-nav-link feature-nav-next">
          <span>
            <span class="nav-label">Next</span>
            <span class="nav-title">{nextFeature.label}</span>
          </span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      ) : <div />}
    </div>
  </div>
</section>

<section class="feature-cta">
  <div class="container">
    <div class="cta-card animate-on-scroll">
      <h2 class="cta-title">Ready to try SAM?</h2>
      <p class="cta-subtitle">Deploy on your own cloud in minutes. Open source, free to self-host.</p>
      <div class="cta-actions">
        <a href={appUrl} class="btn-hero btn-hero-primary">
          Get Started
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="/docs/" class="btn-hero btn-hero-secondary">
          Read the Docs
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* ---- Hero ---- */
  .feature-hero {
    padding: 140px 0 60px;
    text-align: center;
  }

  @media (min-width: 768px) {
    .feature-hero {
      padding: 160px 0 80px;
    }
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    color: var(--color-fg-muted);
    margin-bottom: 32px;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .feature-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-fg-primary);
    margin-bottom: 20px;
  }

  .feature-hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-fg-muted);
    max-width: 640px;
    margin: 0 auto 48px;
    line-height: 1.7;
  }

  .feature-hero-image {
    max-width: 960px;
    margin: 0 auto;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--glass-border);
    box-shadow:
      var(--glass-shadow),
      0 0 60px rgba(22, 163, 74, 0.12),
      0 0 120px rgba(22, 163, 74, 0.06);
  }

  .feature-hero-image picture,
  .feature-hero-image img {
    display: block;
  }

  .feature-hero-image img {
    width: 100%;
    height: auto;
  }

  /* ---- Detail rows (chess layout) ---- */
  .feature-details {
    padding: 80px 0;
  }

  @media (min-width: 768px) {
    .feature-details {
      padding: 120px 0;
    }
  }

  .detail-row {
    display: flex;
    flex-direction: column;
    gap: 32px;
    margin-bottom: 80px;
    align-items: center;
  }

  .detail-row:last-child {
    margin-bottom: 0;
  }

  @media (min-width: 768px) {
    .detail-row {
      flex-direction: row;
      gap: 48px;
      margin-bottom: 100px;
    }

    .detail-row-reverse {
      flex-direction: row-reverse;
    }
  }

  @media (min-width: 1024px) {
    .detail-row {
      gap: 64px;
    }
  }

  .detail-text {
    flex: 1;
    min-width: 0;
  }

  .detail-headline {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-fg-primary);
    margin-bottom: 16px;
  }

  .detail-body {
    font-size: 1rem;
    color: var(--color-fg-muted);
    line-height: 1.7;
  }

  .detail-image {
    flex: 1.2;
    min-width: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
  }

  .detail-image picture,
  .detail-image img {
    display: block;
  }

  .detail-image img {
    width: 100%;
    height: auto;
  }

  .detail-caption {
    display: block;
    padding: 12px 16px;
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    background: var(--glass-bg);
    border-top: 1px solid var(--glass-border);
  }

  /* ---- Feature navigation ---- */
  .feature-nav {
    padding: 40px 0;
    border-top: 1px solid var(--glass-border);
  }

  .feature-nav-inner {
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .feature-nav-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-radius: var(--radius-md);
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    transition: border-color 0.2s, background 0.2s;
    color: inherit;
    max-width: 50%;
  }

  .feature-nav-link:hover {
    border-color: var(--glass-border-hover);
    background: var(--glass-bg-subtle);
    color: inherit;
  }

  .feature-nav-next {
    margin-left: auto;
    text-align: right;
  }

  .nav-label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }

  .nav-title {
    display: block;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-fg-primary);
  }

  /* ---- CTA ---- */
  .feature-cta {
    padding: 80px 0;
  }

  .cta-card {
    text-align: center;
    padding: 64px 32px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--glass-shadow), 0 0 80px rgba(22, 163, 74, 0.08);
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 600;
    color: var(--color-fg-primary);
    margin-bottom: 12px;
  }

  .cta-subtitle {
    font-size: 1.0625rem;
    color: var(--color-fg-muted);
    margin-bottom: 32px;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .btn-hero {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 12px 28px;
    border-radius: var(--radius-md);
    transition: all 0.2s;
    border: none;
    cursor: pointer;
  }

  .btn-hero-primary {
    background: var(--color-accent);
    color: white;
    box-shadow: 0 0 20px rgba(22, 163, 74, 0.3), 0 0 60px rgba(22, 163, 74, 0.1);
  }

  .btn-hero-primary:hover {
    background: var(--color-accent-hover);
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 0 30px rgba(22, 163, 74, 0.4), 0 0 80px rgba(22, 163, 74, 0.15);
  }

  .btn-hero-secondary {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    color: var(--color-fg-primary);
    border: 1px solid var(--glass-border);
  }

  .btn-hero-secondary:hover {
    background: var(--glass-bg-subtle);
    color: var(--color-fg-primary);
    border-color: var(--glass-border-hover);
  }

  :global(html[data-theme='light']) .feature-hero-image {
    box-shadow:
      var(--glass-shadow),
      0 0 50px rgba(21, 128, 61, 0.08),
      0 0 100px rgba(21, 128, 61, 0.04);
  }

  :global(html[data-theme='light']) .cta-card {
    box-shadow: var(--glass-shadow), 0 0 70px rgba(21, 128, 61, 0.06);
  }

  :global(html[data-theme='light']) .btn-hero-primary {
    box-shadow: 0 0 20px var(--shadow-accent-soft), 0 0 60px var(--color-accent-glow);
  }

  :global(html[data-theme='light']) .btn-hero-primary:hover {
    box-shadow: 0 0 30px var(--shadow-accent-strong), 0 0 80px var(--color-accent-glow);
  }
</style>
