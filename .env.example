# Cloudflare Configuration
CF_API_TOKEN=your-cloudflare-api-token
CF_ZONE_ID=your-zone-id
CF_ACCOUNT_ID=your-account-id

# Domain Configuration
BASE_DOMAIN=example.com

# GitHub OAuth (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# GitHub App (create at https://github.com/settings/apps)
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY=your-github-app-private-key-base64
GITHUB_APP_SLUG=your-github-app-slug

# GitLab OAuth (optional fallback; runtime setup/admin config takes precedence)
GITLAB_HOST=https://gitlab.com
GITLAB_CLIENT_ID=your-gitlab-oauth-application-id
GITLAB_CLIENT_SECRET=your-gitlab-oauth-secret

# Security keys (production deploys auto-generate these with Pulumi)
# For local development, generate with: tsx scripts/deploy/generate-keys.ts
JWT_PRIVATE_KEY=your-jwt-private-key-base64
JWT_PUBLIC_KEY=your-jwt-public-key-base64

# Encryption key for credential storage (32 bytes, base64)
ENCRYPTION_KEY=your-encryption-key-base64

# Deployment signing keys (Ed25519, base64; production auto-generated)
DEPLOY_SIGNING_PRIVATE_KEY=your-deploy-signing-private-key-base64
DEPLOY_SIGNING_PUBLIC_KEY=your-deploy-signing-public-key-base64

# Deployment runtime configuration
BUILD_PUBLISH_TOOL_TIMEOUT_MS=1260000
DEPLOYMENT_ROUTE_PORT_BASE=35000
DEPLOYMENT_ROUTE_PORT_SPAN=100
DEPLOYMENT_DEFAULT_VM_SIZE=small
DEPLOYMENT_MODEL_RUNNER_VM_SIZE=medium
MAX_ENVIRONMENTS_PER_DEPLOYMENT_NODE=5
DEPLOYMENT_DEFAULT_MEMORY_LIMIT_MB=256
DEPLOYMENT_LOG_MAX_SIZE=10m
MCP_DEPLOYMENT_COMPOSE_PREVIEW_MAX_BYTES=128000
DEPLOYMENT_LOG_MAX_FILE=3
DEPLOY_ACME_EMAIL=
DEPLOY_ACME_CA=
DEPLOY_COMPOSE_CMD=docker compose
DEPLOY_HEALTH_TIMEOUT=5m

# Development
NODE_ENV=development
# Generic webhook triggers (all values optional; defaults shown)
WEBHOOK_TRIGGERS_ENABLED=true
WEBHOOK_TRIGGER_MAX_BODY_BYTES=65536
WEBHOOK_TRIGGER_MAX_FILTERS=10
WEBHOOK_TRIGGER_MAX_FILTER_PATH_LENGTH=200
WEBHOOK_TRIGGER_MAX_FILTER_PATH_DEPTH=8
WEBHOOK_TRIGGER_MAX_INCLUDED_HEADERS=10
WEBHOOK_TRIGGER_MAX_HEADER_NAME_LENGTH=100
WEBHOOK_TRIGGER_MAX_SOURCE_LABEL_LENGTH=100
WEBHOOK_TRIGGER_MAX_IDEMPOTENCY_KEY_LENGTH=200
WEBHOOK_INGRESS_RATE_LIMIT_PER_MINUTE=120
WEBHOOK_TRIGGER_RATE_LIMIT_PER_MINUTE=60
WEBHOOK_INVALID_TOKEN_RATE_LIMIT_PER_MINUTE=30
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60
WEBHOOK_DELIVERY_RETENTION_DAYS=7
WEBHOOK_DELIVERY_CLEANUP_BATCH_SIZE=500
WEBHOOK_DELIVERY_DEFAULT_PAGE_SIZE=25
WEBHOOK_DELIVERY_MAX_PAGE_SIZE=100
WEBHOOK_DELIVERY_PROCESSING_LEASE_SECONDS=300
